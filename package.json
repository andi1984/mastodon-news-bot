{
  "name": "mastodon_news_bot",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "main": "src/index.ts",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "jest",
    "watch": "TS_NODE=true NODE_OPTIONS=\"--loader ts-node/esm\" nodemon ./src/index.ts",
    "build": "tsc && mkdir -p dist/data && cp src/data/settings.json dist/data/settings.json",
    "dev": "TS_NODE=true NODE_OPTIONS=\"--loader ts-node/esm\" node src/index.ts",
    "start": "node ./scripts/create-env.cjs && node ./dist/index.js",
    "cleanup-replies": "TS_NODE=true NODE_OPTIONS=\"--loader ts-node/esm\" node scripts/cleanup-auto-replies.ts",
    "daily-digest": "TS_NODE=true NODE_OPTIONS=\"--loader ts-node/esm\" node src/jobs/daily-digest.ts",
    "weekly-digest": "TS_NODE=true NODE_OPTIONS=\"--loader ts-node/esm\" node src/jobs/weekly-digest.ts",
    "manage-feeds": "TS_NODE=true NODE_OPTIONS=\"--loader ts-node/esm\" node scripts/manage-feeds.ts"
  },
  "author": "Andreas Sander (mail@andi1984.de)",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@supabase/supabase-js": "^2.0.3",
    "bree": "^9.1.2",
    "crypto-js": "^4.1.1",
    "dotenv": "^16.0.3",
    "jest": "^29.3.1",
    "masto": "^7.0.0",
    "mastodon-api": "^1.3.0",
    "node-cron": "^3.0.2",
    "prettier": "2.7.1",
    "rss-parser": "^3.12.0",
    "ts-jest": "^29.0.3"
  },
  "devDependencies": {
    "@tsconfig/node18": "^1.0.1",
    "@types/crypto-js": "^4.1.1",
    "@types/jest": "^29.2.2",
    "@types/node": "^18.11.3",
    "@types/node-cron": "^3.0.4",
    "nodemon": "^2.0.20",
    "ts-node": "^10.9.1",
    "typescript": "^4.8.4"
  },
  "private": true,
  "jest": {
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": {
            "module": "commonjs",
            "moduleResolution": "node",
            "resolveJsonModule": true,
            "esModuleInterop": true,
            "types": [
              "node",
              "jest"
            ]
          },
          "diagnostics": false
        }
      ]
    },
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/dist/"
    ]
  }
}
