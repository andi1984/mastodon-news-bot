{
  "name": "mastodon_news_bot",
  "version": "1.1.0",
  "description": "Mastodon news bot with RSS feed aggregation",
  "type": "module",
  "main": "src/index.ts",
  "engines": {
    "node": ">=20.6.0"
  },
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "watch": "tsx watch ./src/index.ts",
    "build": "tsc && mkdir -p dist/data && cp src/data/settings.json dist/data/settings.json",
    "dev": "tsx src/index.ts",
    "start": "node ./scripts/create-env.cjs && node ./dist/index.js",
    "cleanup-replies": "tsx scripts/cleanup-auto-replies.ts",
    "cleanup-duplicates": "tsx scripts/cleanup-duplicate-toots.ts",
    "fix-story-toots": "tsx src/scripts/fix-duplicate-toots.ts",
    "story-thread-fixer": "tsx src/jobs/story-thread-fixer.ts",
    "daily-digest": "tsx src/jobs/daily-digest.ts",
    "weekly-digest": "tsx src/jobs/weekly-digest.ts",
    "manage-feeds": "tsx scripts/manage-feeds.ts",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "author": "Andreas Sander (mail@andi1984.de)",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@supabase/supabase-js": "^2.99.3",
    "bree": "^9.2.9",
    "dotenv": "^17.3.1",
    "masto": "^7.10.2",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@tsconfig/node20": "^20.1.5",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.27",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "tsx": "^4.19.4",
    "typescript": "^5.9.3"
  },
  "private": true,
  "jest": {
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "useESM": true,
          "tsconfig": {
            "module": "ESNext",
            "moduleResolution": "bundler",
            "resolveJsonModule": true,
            "esModuleInterop": true,
            "types": [
              "node",
              "jest"
            ]
          },
          "diagnostics": false
        }
      ]
    },
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/dist/"
    ],
    "resetMocks": false,
    "clearMocks": true,
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.test.ts",
      "!src/index.ts",
      "!src/types/**",
      "!src/data/**",
      "!src/jobs/**",
      "!src/scripts/**"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "text-summary",
      "lcov",
      "json-summary",
      "json"
    ]
  }
}
