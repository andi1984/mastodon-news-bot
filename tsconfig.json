{
  "extends": "@tsconfig/node20/tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "types": ["node", "jest"],
    "rootDir": "./src/",
    "outDir": "./dist/"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "scripts", "**/*.test.ts"]
}
